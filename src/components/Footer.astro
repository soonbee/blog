---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
</footer>
<style>
	footer {
		padding: 1.25em 1em;
		border-top: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.85em;
	}
</style>
