---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;          // OG 이미지 경로 (없으면 기본 이미지)
  article?: boolean;       // 글이면 og:type=article
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  title,
  description,
  image = '/og-default.png',
  article = false,
  pubDate,
  updatedDate,
} = Astro.props;

// 절대 URL 만들기 — Astro.site 기반
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);

// 브라우저 탭 제목: 홈은 사이트명만, 그 외엔 "제목 · 사이트명"
const pageTitle = title === SITE_TITLE ? title : `${title} · ${SITE_TITLE}`;

// 구조화 데이터 (검색엔진용)
const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImageURL.toString(),
      url: canonicalURL.toString(),
      datePublished: pubDate?.toISOString(),
      dateModified: (updatedDate ?? pubDate)?.toISOString(),
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: SITE_TITLE,
      description,
      url: new URL('/', Astro.site).toString(),
    };
---

<!-- 기본 -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)" />

<!-- SEO 핵심 -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- RSS / 사이트맵 -->
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Open Graph -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="ko_KR" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={title} />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- 구조화 데이터 -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
