---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;   // 3단계 image()가 만든 타입
  tags?: string[];
}
const { title, description, pubDate, updatedDate, heroImage, tags = [] } = Astro.props;
---

<BaseLayout {title} {description} article pubDate={pubDate} image={heroImage?.src}>
  <article>
    {heroImage && (
      <Image
        src={heroImage}
        alt={title}
        widths={[400, 720, 1080, 1440]}
        sizes="(max-width: 720px) 100vw, 720px"
        loading="eager"
        fetchpriority="high"
        quality={80}
      />
    )}
    <h1>{title}</h1>
    <time datetime={pubDate.toISOString()}>
      {pubDate.toLocaleDateString('ko-KR')}
    </time>
    {updatedDate && <p>수정: {updatedDate.toLocaleDateString('ko-KR')}</p>}
    <slot />   <!-- 4단계의 <Content /> 가 여기 들어옴 -->
    {tags.length > 0 && (
      <footer class="tags">
        {tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}
      </footer>
    )}
  </article>
</BaseLayout>