---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="페이지를 찾을 수 없습니다.">
  <section class="not-found">
    <p class="code">404</p>
    <h1>페이지를 찾을 수 없습니다</h1>
    <p>주소가 바뀌었거나 삭제된 페이지일 수 있어요.</p>
    <a href="/">← 홈으로 돌아가기</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 1rem;
  }
  .code {
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    margin: 0;
    color: var(--accent);
  }
  .not-found h1 {
    margin: 0.5rem 0 1rem;
  }
  .not-found a {
    display: inline-block;
    margin-top: 1.5rem;
  }
</style>
